<%= form_with(model: eat) do |form| %>
  <% if eat.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(eat.errors.count, "error") %> prohibited this eat from being saved:</h2>

      <ul>
        <% eat.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :price, style: "display: block" %>
    <%= form.number_field :price %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
